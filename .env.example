# Backend Configuration for Render
# Copy this file to .env and update the values for your deployment

# Database URL (Render will provide PostgreSQL URL)
# For PostgreSQL: postgresql://user:password@host:port/dbname
# For SQLite (development): sqlite:///./app.db
DATABASE_URL=postgresql://user:password@localhost/campus_lost_found

# CORS Origins (comma-separated list of allowed frontend URLs)
# For development: http://localhost:3000
# For production: https://your-frontend-domain.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app

# JWT Secret (use a strong random string for production)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-this-in-production

# Environment Mode
ENVIRONMENT=development

# Port (Render will set PORT env var automatically)
# PORT=8000

# Gunicorn Workers (for production)
WORKERS=4

# Optional: Database pool settings for PostgreSQL
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
